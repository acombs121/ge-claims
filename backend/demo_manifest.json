{
  "steps": [
    {
      "phase": 1,
      "trigger_queries": [
        "let's see standard widgets overview",
        "show standard widgets",
        "widget showcase",
        "A2UI standard components"
      ],
      "fuzzy_matching": true,
      "action_tool": "get_standard_widgets_overview",
      "output_mode": "native",
      "native_mapper": "build_showcase_widgets_card"
    },
    {
      "phase": 2,
      "trigger_queries": [
        "show map visualization",
        "interactive leaflet map",
        "load maps demo",
        "route optimization map"
      ],
      "fuzzy_matching": true,
      "action_tool": "get_map_visualization",
      "output_mode": "iframe",
      "template": "base_map"
    },
    {
      "phase": 2.5,
      "trigger_queries": [
        "give me a simple google map",
        "simple map URL"
      ],
      "fuzzy_matching": true,
      "action_tool": "get_map_visualization",
      "action_tool_args": {
        "intent": "simple"
      },
      "output_mode": "url"
    },
    {
      "phase": 3,
      "trigger_queries": [
        "show universal dashboard",
        "show the universal dashboard",
        "kpi simulator dashboard"
      ],
      "fuzzy_matching": true,
      "action_tool": "get_universal_dashboard_data",
      "output_mode": "iframe",
      "template": "universal_dashboard"
    },
    {
      "phase": 3.5,
      "trigger_queries": [
        "load D3 network dashboard"
      ],
      "fuzzy_matching": true,
      "action_tool": "get_d3_network_data",
      "output_mode": "iframe",
      "template": "dashboard"
    },
    {
      "phase": 4,
      "trigger_queries": [
        "give me an audio summary",
        "podcast voice briefing",
        "audio presentation summary"
      ],
      "fuzzy_matching": false,
      "action_tool": "generate_audio_summary",
      "output_mode": "native",
      "native_mapper": "build_audio_card",
      "audio_config": {
        "mode": "podcast",
        "voices": ["Aoede", "Charon"],
        "speakers": ["Host", "Expert"]
      }
    },
    {
      "phase": 5,
      "trigger_queries": [
        "generate custom visual graphic",
        "multimodal image generation"
      ],
      "fuzzy_matching": false,
      "action_tool": "generate_hr_graphic",
      "output_mode": "native",
      "native_mapper": "build_image_card"
    }
  ]
}